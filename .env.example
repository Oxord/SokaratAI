OPENROUTER_API_KEY=mock-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_REFERER=https://sokrat.local
MODEL_NAME=anthropic/claude-sonnet-4
# Модель для технических ролей (программисты, DevOps, QA и т.п.)
MODEL_TECH=anthropic/claude-sonnet-4-5
# Модель для нетехнических ролей (дворник, кассир, продавец...).
# Также используется одноразово для классификации произвольных ролей.
MODEL_GENERAL=deepseek/deepseek-chat
# Если MODEL_TECH/MODEL_GENERAL не заданы, обе категории падают на MODEL_NAME.
INTERVIEW_QUESTIONS_COUNT=7
SESSION_DIR=data/sessions
QUESTIONS_PATH=data/questions.json

# ── SaluteSpeech (Sber STT) ─────────────────────────────────────────────────
# base64(client_id:client_secret) из личного кабинета SmartSpeech.
# Без этого ключа кнопка микрофона ответит сообщением, что STT не настроен.
SBER_SALUTE_AUTH_KEY=
# SALUTE_SPEECH_PERS — для физлиц, SALUTE_SPEECH_CORP — для юрлиц.
SBER_SALUTE_SCOPE=SALUTE_SPEECH_PERS
# Endpoint Сбера использует Russian Trusted Root CA (Минцифры).
# Если в системе его нет — укажи путь к bundle:
# SBER_SALUTE_CA_BUNDLE=/path/to/russian_trusted_root_ca.pem
# Или (только для локальной разработки!) выключи проверку TLS:
# SBER_SALUTE_VERIFY_SSL=false
